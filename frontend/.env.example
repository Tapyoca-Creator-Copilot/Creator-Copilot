# Copy to frontend/.env and fill values

# Supabase (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# (Optional) Alternative naming some setups use:
# VITE_SUPABASE_ANON_KEY=

# Backend API base URL
VITE_API_URL=http://localhost:5001

# AI server base URL (required in production)
# Leave blank for local dev if using Vite proxy
VITE_AI_SERVER_URL=
