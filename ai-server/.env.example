# Copy to ai-server/.env and fill values

# Gemini key (required)
GOOGLE_GENERATIVE_AI_API_KEY=

# Server port
PORT=8787

# Gemini model (optional)
GEMINI_MODEL=gemini-3-flash-preview

# Backend base URL
BACKEND_URL=http://localhost:5001

# CORS allowlist origin (recommended in production)
FRONTEND_URL=